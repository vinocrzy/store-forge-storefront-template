# ─── Storefront Template – Environment Example ───────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ── API ──────────────────────────────────────────────────────────────────────
# Base URL of the Laravel backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Store Identity ────────────────────────────────────────────────────────────
# Numeric ID of this store in the backend database
NEXT_PUBLIC_STORE_ID=1
# Human-readable store name (used in page titles, OG tags, etc.)
NEXT_PUBLIC_STORE_NAME=My Store

# ── Site URL ──────────────────────────────────────────────────────────────────
# Full public URL of this storefront (used for canonical URLs, sitemaps, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
